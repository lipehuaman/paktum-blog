---
const {
  title = 'Paktum Blog',
  description = '',
  lang = 'de',
  deUrl = '/blog',
  enUrl = '/blog/en',
  esUrl = null,
} = Astro.props;
const SITE = 'https://www.paktum.ch';
const canonicalPath = lang === 'en' ? enUrl : lang === 'es' ? esUrl : deUrl;
const blogIndex = lang === 'en' ? '/blog/en' : lang === 'es' ? '/blog/es' : '/blog';
const ogLocale = lang === 'en' ? 'en_US' : lang === 'es' ? 'es_ES' : 'de_DE';
const langCode = lang === 'en' ? 'EN' : lang === 'es' ? 'ES' : 'DE';
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={SITE + canonicalPath} />
    <link rel="alternate" hreflang="de" href={SITE + deUrl} />
    {enUrl && <link rel="alternate" hreflang="en" href={SITE + enUrl} />}
    {esUrl && <link rel="alternate" hreflang="es" href={SITE + esUrl} />}
    <link rel="alternate" hreflang="x-default" href={SITE + deUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={SITE + canonicalPath} />
    <meta property="og:image" content={`${SITE}/og-image.png`} />
    <meta property="og:site_name" content="Paktum" />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE}/og-image.png`} />

    <script is:inline src="https://web.cmp.usercentrics.eu/modules/autoblocker.js"></script>
    <script is:inline id="usercentrics-cmp" src="https://web.cmp.usercentrics.eu/ui/loader.js" data-settings-id="vroPjhUClfR6mc" async></script>

    <link rel="stylesheet" href="https://use.typekit.net/apb2slf.css" />
    <style is:global>
      :root {
        --color-primary: #970EFB;
        --color-primary-hover: #AD2FFC;
        --color-primary-soft: rgba(151, 14, 251, 0.1);
        --color-bg-base: #F4F2EE;
        --color-bg-surface: #FFFFFF;
        --color-ink: #0A0612;
        --color-ink-soft: #1F0F3D;
        --color-text-primary: #0A0612;
        --color-text-secondary: #635A6F;
        --color-text-muted: #908AA0;
        --color-border: rgba(10, 6, 18, 0.1);
        --font-display: 'forma-djr-display', 'forma-djr-text', 'Inter', 'Helvetica Neue', 'Arial', system-ui, sans-serif;
        --container: 1320px;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { font-family: var(--font-display); background: var(--color-bg-base); color: var(--color-text-primary); -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; line-height: 1.4; overflow-x: hidden; }
      img { max-width: 100%; display: block; }
      .container { max-width: var(--container); margin: 0 auto; padding: 0 32px; }
      .accent { color: var(--color-primary); font-style: italic; }
      .navbar { position: fixed; top: 20px; left: 50%; transform: translateX(-50%); width: calc(100% - 48px); max-width: 1400px; z-index: 100; background: rgba(10, 6, 18, 0.85); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-radius: 100px; padding: 12px 16px 12px 24px; display: flex; justify-content: space-between; align-items: center; color: white; border: 1px solid rgba(244, 242, 238, 0.12); }
      .nav-logo { display: flex; align-items: center; text-decoration: none; }
      .nav-logo img { height: 28px; width: auto; display: block; }
      .nav-links { display: flex; gap: 32px; list-style: none; }
      .nav-links a { color: #F4F2EE; text-decoration: none; font-size: 14px; font-weight: 500; letter-spacing: 0.04em; opacity: 0.8; transition: opacity 0.2s; }
      .nav-links a:hover, .nav-links a.active { opacity: 1; }
      .nav-actions { display: flex; align-items: center; gap: 20px; }
      .btn-cta { background: var(--color-primary); color: #fff; text-decoration: none; font-size: 14px; font-weight: 600; padding: 12px 22px; border-radius: 100px; transition: background 0.2s; white-space: nowrap; }
      .btn-cta:hover { background: var(--color-primary-hover); }
      .hamburger-btn { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 6px; }
      .hamburger-btn span { width: 22px; height: 2px; background: #fff; border-radius: 2px; transition: 0.25s; }
      .hamburger-btn.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      .hamburger-btn.is-open span:nth-child(2) { opacity: 0; }
      .hamburger-btn.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
      .mobile-menu { display: none; position: fixed; top: 84px; left: 50%; transform: translateX(-50%); width: calc(100% - 48px); max-width: 1400px; z-index: 99; background: rgba(10, 6, 18, 0.95); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(244, 242, 238, 0.12); border-radius: 24px; padding: 16px; flex-direction: column; gap: 4px; }
      .mobile-menu.open { display: flex; }
      .mobile-menu a { color: #F4F2EE; text-decoration: none; font-size: 16px; font-weight: 500; padding: 12px 16px; border-radius: 12px; }
      .mobile-menu a:hover { background: rgba(255,255,255,0.06); }
      .site-footer { background: var(--color-bg-base); padding: 80px 16px 32px; margin-top: 96px; }
      .footer-container { max-width: var(--container); margin: 0 auto; }
      .footer-cols { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 64px; padding-top: 48px; border-top: 1px solid var(--color-border); margin-bottom: 48px; }
      .footer-logo-img { height: 30px; width: auto; margin-bottom: 16px; }
      .footer-brand p { color: var(--color-text-secondary); font-size: 14px; line-height: 1.6; max-width: 360px; }
      .footer-col h5 { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-muted); margin-bottom: 16px; }
      .footer-col ul { list-style: none; }
      .footer-col li { margin-bottom: 10px; }
      .footer-col a { color: var(--color-text-primary); text-decoration: none; font-size: 14px; opacity: 0.85; }
      .footer-col a:hover { opacity: 1; color: var(--color-primary); }
      .footer-bottom { display: flex; justify-content: space-between; align-items: center; padding-top: 24px; border-top: 1px solid var(--color-border); font-size: 13px; color: var(--color-text-muted); }
      .swiss-made { height: 36px; width: auto; }
      .blog-hero { padding: 160px 32px 48px; max-width: 900px; }
      .eyebrow { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-primary); margin-bottom: 16px; }
      .blog-hero h1 { font-size: clamp(40px, 6vw, 76px); font-weight: 700; line-height: 1; letter-spacing: -0.01em; }
      .blog-hero .lead { margin-top: 24px; font-size: 19px; line-height: 1.5; color: var(--color-text-secondary); max-width: 560px; }
      .blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; padding-bottom: 40px; }
      .post-card { display: flex; flex-direction: column; background: var(--color-bg-surface); border: 1px solid var(--color-border); border-radius: 20px; overflow: hidden; text-decoration: none; color: inherit; transition: transform 0.25s ease, box-shadow 0.25s ease; }
      .post-card:hover { transform: translateY(-4px); box-shadow: 0 18px 40px rgba(10, 6, 18, 0.10); }
      .post-card-media { aspect-ratio: 16 / 9; background: var(--color-bg-base); overflow: hidden; }
      .post-card-media img { width: 100%; height: 100%; object-fit: cover; }
      .post-card-body { padding: 24px; display: flex; flex-direction: column; gap: 12px; flex: 1; }
      .post-card-cat { align-self: flex-start; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-primary); background: var(--color-primary-soft); padding: 4px 10px; border-radius: 100px; }
      .post-card h2 { font-size: 22px; font-weight: 700; line-height: 1.15; }
      .post-card-body p { font-size: 15px; line-height: 1.5; color: var(--color-text-secondary); flex: 1; }
      .post-card-meta { font-size: 13px; color: var(--color-text-muted); }
      .article { max-width: 720px; margin: 0 auto; padding: 150px 32px 0; }
      .article-cat { display: inline-block; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-primary); background: var(--color-primary-soft); padding: 5px 12px; border-radius: 100px; margin-bottom: 20px; }
      .article h1 { font-size: clamp(34px, 5vw, 54px); font-weight: 700; line-height: 1.08; letter-spacing: -0.01em; }
      .article-lead { margin-top: 20px; font-size: 20px; line-height: 1.5; color: var(--color-text-secondary); }
      .article-meta { margin-top: 24px; display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--color-text-muted); }
      .article-cover { margin: 40px 0; border-radius: 20px; overflow: hidden; }
      .article-cover img { width: 100%; height: auto; }
      .article-body { font-size: 18px; line-height: 1.75; color: var(--color-text-primary); padding-bottom: 24px; }
      .article-body h2 { font-size: 30px; font-weight: 700; line-height: 1.2; margin: 48px 0 16px; letter-spacing: -0.01em; }
      .article-body h3 { font-size: 23px; font-weight: 700; line-height: 1.25; margin: 36px 0 12px; }
      .article-body p { margin: 0 0 24px; }
      .article-body a { color: var(--color-primary); text-decoration: underline; text-underline-offset: 3px; }
      .article-body ul, .article-body ol { margin: 0 0 24px 24px; }
      .article-body li { margin-bottom: 8px; }
      .article-body img { width: 100%; border-radius: 16px; margin: 32px 0; }
      .article-body blockquote { margin: 32px 0; padding: 8px 0 8px 24px; border-left: 3px solid var(--color-primary); font-size: 21px; line-height: 1.5; color: var(--color-ink-soft); font-style: italic; }
      .article-foot { max-width: 720px; margin: 0 auto; padding: 32px; margin-bottom: 48px; }
      .back-link { color: var(--color-primary); text-decoration: none; font-weight: 600; font-size: 15px; }
      .back-link:hover { text-decoration: underline; }
      @media (max-width: 980px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
      @media (max-width: 880px) { .nav-links { display: none; } .nav-lang { display: none; } .nav-actions .btn-cta { display: none; } .hamburger-btn { display: flex; } .lang-floating { display: flex; } }
      @media (max-width: 720px) { .footer-cols { grid-template-columns: 1fr; gap: 40px; } }
      @media (max-width: 640px) { .blog-grid { grid-template-columns: 1fr; } .blog-hero { padding-top: 130px; } .article { padding-top: 120px; } .article-body { font-size: 17px; } }

      .nav-lang { position: relative; display: flex; align-items: center; gap: 0; }
      .lang-trigger { display: inline-flex; align-items: center; gap: 6px; background: transparent; border: none; cursor: pointer; color: rgba(244,242,238,0.7); font-family: inherit; font-size: 12px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; padding: 6px 8px; border-radius: 100px; transition: color 0.2s; }
      .lang-trigger:hover { color: #fff; }
      .lang-trigger .lang-globe { width: 15px; height: 15px; opacity: 0.7; flex-shrink: 0; }
      .lang-trigger .lang-caret { width: 9px; height: 9px; opacity: 0.6; flex-shrink: 0; transition: transform 0.2s, color 0.2s; }
      .nav-lang.open .lang-trigger .lang-caret, .lang-floating.open .lang-trigger .lang-caret { transform: rotate(180deg); color: var(--color-primary); opacity: 1; }
      .lang-menu { position: absolute; top: calc(100% + 8px); right: 0; min-width: 140px; background: #15101F; border: 1px solid rgba(244,242,238,0.12); border-radius: 12px; padding: 4px; display: none; flex-direction: column; box-shadow: 0 12px 32px rgba(10,6,18,0.4); z-index: 200; }
      .nav-lang.open .lang-menu, .lang-floating.open .lang-menu { display: flex; }
      .lang-menu .lang-btn { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 9px 12px; border-radius: 8px; color: rgba(244,242,238,0.7); text-decoration: none; font-family: inherit; font-size: 13px; font-weight: 400; letter-spacing: 0; text-transform: none; transition: background 0.15s, color 0.15s; }
      .lang-menu .lang-btn:hover { background: rgba(255,255,255,0.06); color: #fff; }
      .lang-menu .lang-btn.active { color: var(--color-primary); font-weight: 500; background: rgba(151,14,251,0.12); }
      .lang-menu .lang-check { width: 14px; height: 14px; opacity: 0; flex-shrink: 0; }
      .lang-menu .lang-btn.active .lang-check { opacity: 1; }
      .lang-floating { position: fixed; bottom: 16px; right: 16px; z-index: 101; display: none; padding: 0; background: transparent; border: none; box-shadow: none; }
      .lang-floating .lang-trigger { background: rgba(10,6,18,0.92); border: 1px solid rgba(244,242,238,0.15); box-shadow: 0 8px 24px rgba(10,6,18,0.25); padding: 8px 14px; }
      .lang-floating .lang-menu { top: auto; bottom: calc(100% + 8px); right: 0; }
      @media (max-width: 880px) { .lang-floating { display: flex; } }
    </style>
  </head>
  <body>
    <nav class="navbar">
      <a href="https://www.paktum.ch/" class="nav-logo"><img src="https://www.paktum.ch/SVG%20Logos/Recurso%206.svg" alt="Paktum" /></a>
      <ul class="nav-links">
        <li><a href="https://www.paktum.ch/#product">Product</a></li>
        <li><a href="https://www.paktum.ch/#features">Features</a></li>
        <li><a href="https://www.paktum.ch/#stats">Value</a></li>
        <li><a href="https://www.paktum.ch/pricing">Pricing</a></li>
        <li><a href="https://www.paktum.ch/about">About Us</a></li>
        <li><a href={blogIndex} class="active">Blog</a></li>
      </ul>
      <div class="nav-actions">
        <div class="nav-lang">
          <button type="button" class="lang-trigger" aria-haspopup="true" aria-expanded="false" aria-label="Sprache waehlen"><svg class="lang-globe" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 2.5 16 0 18M12 3c-2.5 2.5-2.5 16 0 18"/></svg><span class="lang-current">{langCode}</span><svg class="lang-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></button>
          <div class="lang-menu">
            <a href={deUrl} class={lang === 'de' ? 'lang-btn active' : 'lang-btn'}><span>Deutsch</span><svg class="lang-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L19 7"/></svg></a>
            <a href={enUrl ? enUrl : '/blog/en'} class={lang === 'en' ? 'lang-btn active' : 'lang-btn'}><span>English</span><svg class="lang-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L19 7"/></svg></a>
            <a href={esUrl ? esUrl : '/blog/es'} class={lang === 'es' ? 'lang-btn active' : 'lang-btn'}><span>Español</span><svg class="lang-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L19 7"/></svg></a>
          </div>
        </div>
        <a href="https://www.paktum.ch/book-a-demo" class="btn-cta">Book a demo</a>
        <button class="hamburger-btn" id="hamburger" aria-label="Menu" aria-expanded="false"><span></span><span></span><span></span></button>
      </div>
    </nav>
    <div class="mobile-menu" id="mobileMenu">
      <a href="https://www.paktum.ch/#product">Product</a>
      <a href="https://www.paktum.ch/#features">Features</a>
      <a href="https://www.paktum.ch/#stats">Value</a>
      <a href="https://www.paktum.ch/pricing">Pricing</a>
      <a href="https://www.paktum.ch/about">About Us</a>
      <a href={blogIndex}>Blog</a>
      <a href="https://www.paktum.ch/book-a-demo" class="btn-cta" style="text-align:center; margin-top:8px;">Book a demo</a>
    </div>
    <div class="lang-floating">
      <button type="button" class="lang-trigger" aria-haspopup="true" aria-expanded="false" aria-label="Sprache waehlen"><svg class="lang-globe" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 2.5 16 0 18M12 3c-2.5 2.5-2.5 16 0 18"/></svg><span class="lang-current">{langCode}</span><svg class="lang-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></button>
      <div class="lang-menu">
            <a href={deUrl} class={lang === 'de' ? 'lang-btn active' : 'lang-btn'}><span>Deutsch</span><svg class="lang-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L19 7"/></svg></a>
            <a href={enUrl ? enUrl : '/blog/en'} class={lang === 'en' ? 'lang-btn active' : 'lang-btn'}><span>English</span><svg class="lang-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L19 7"/></svg></a>
            <a href={esUrl ? esUrl : '/blog/es'} class={lang === 'es' ? 'lang-btn active' : 'lang-btn'}><span>Español</span><svg class="lang-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L19 7"/></svg></a>
      </div>
    </div>
    <main><slot /></main>
    <footer class="site-footer">
      <div class="footer-container">
        <div class="footer-cols">
          <div class="footer-brand">
            <img class="footer-logo-img" src="https://www.paktum.ch/SVG%20Logos/Recurso%205.svg" alt="Paktum" />
            <p>Das Schweizer Taschenmesser für dein Sponsoring. Ein Produkt der KLTechnologies GmbH, mit Sitz in Luzern, Schweiz.</p>
          </div>
          <div class="footer-col">
            <h5>Product</h5>
            <ul>
              <li><a href="https://www.paktum.ch/#features">Features</a></li>
              <li><a href="https://www.paktum.ch/pricing">Pricing</a></li>
              <li><a href={blogIndex}>Blog</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h5>Legal</h5>
            <ul><li><a href="https://www.paktum.ch/impressum">Imprint</a></li></ul>
          </div>
        </div>
        <div class="footer-bottom">
          <span>© 2026 KLTechnologies GmbH</span>
          <img class="swiss-made" src="https://www.paktum.ch/SVG%20Logos/Swiss_Made.svg" alt="Swiss Made" />
        </div>
      </div>
    </footer>
    <script is:inline>
      (function () {
        var hb = document.getElementById('hamburger');
        var mm = document.getElementById('mobileMenu');
        if (hb && mm) {
          hb.addEventListener('click', function () {
            var open = mm.classList.toggle('open');
            hb.classList.toggle('is-open', open);
            hb.setAttribute('aria-expanded', open ? 'true' : 'false');
          });
        }
        document.querySelectorAll('.lang-trigger').forEach(function(trigger){
          trigger.addEventListener('click', function(e){
            e.preventDefault(); e.stopPropagation();
            var container = trigger.closest('.nav-lang, .lang-floating');
            var willOpen = !container.classList.contains('open');
            document.querySelectorAll('.nav-lang, .lang-floating').forEach(function(c){ c.classList.remove('open'); });
            document.querySelectorAll('.lang-trigger').forEach(function(t){ t.setAttribute('aria-expanded','false'); });
            if (willOpen) { container.classList.add('open'); trigger.setAttribute('aria-expanded','true'); }
          });
        });
        document.addEventListener('click', function(){
          document.querySelectorAll('.nav-lang, .lang-floating').forEach(function(c){ c.classList.remove('open'); });
          document.querySelectorAll('.lang-trigger').forEach(function(t){ t.setAttribute('aria-expanded','false'); });
        });
      })();
    </script>
  </body>
</html>
