---
import { useStoryblokApi } from '@storyblok/astro';

const storyblokApi = useStoryblokApi();
const { data } = await storyblokApi.get('cdn/stories', {
  version: 'draft',
});
console.log('STORYBLOK DATA:', JSON.stringify(data, null, 2));
const stories = (data?.stories ?? []) as any[];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>Test de conexion Storyblok</title>
  </head>
  <body>
    <h1>Conexion con Storyblok</h1>
    <p>Stories encontradas: {stories.length}</p>
    <ul>
      {stories.map((story) => <li>{story.name} ({story.full_slug})</li>)}
    </ul>
  </body>
</html>