---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useStoryblokApi } from '@storyblok/astro';

const storyblokApi = useStoryblokApi();
const { data } = await storyblokApi.get('cdn/stories', {
  version: import.meta.env.DEV ? 'draft' : 'published',
  starts_with: 'blog/',
  content_type: 'blogPost',
  language: 'en',
});
const posts = data.stories.filter((s) => s.content.available_en);

function formatDate(d) {
  return d ? new Date(d).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
}
---
<BaseLayout title="Blog · Paktum" description="Insights and updates on sponsorship from Paktum." lang="en" deUrl="/blog" enUrl="/blog/en" esUrl="/blog/es">
  <section class="blog-hero container">
    <p class="eyebrow">Paktum Blog</p>
    <h1>Sponsoring, <span class="accent">reimagined</span>.</h1>
    <p class="lead">Insights, practical tips and updates on managing your sponsorship.</p>
  </section>
  <section class="blog-grid container">
    {posts.map((post) => (
      <a class="post-card" href={`/blog/en/${post.slug}`}>
        {post.content.cover?.filename && (
          <div class="post-card-media"><img src={`${post.content.cover.filename}/m/800x450`} alt={post.content.cover.alt || post.content.title} /></div>
        )}
        <div class="post-card-body">
          {post.content.category && <span class="post-card-cat">{post.content.category}</span>}
          <h2>{post.content.title}</h2>
          {post.content.excerpt && <p>{post.content.excerpt}</p>}
          <span class="post-card-meta">{formatDate(post.content.published_date)}</span>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>
