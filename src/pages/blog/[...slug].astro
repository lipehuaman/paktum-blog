---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useStoryblokApi } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';

export async function getStaticPaths() {
  const storyblokApi = useStoryblokApi();
  const { data } = await storyblokApi.get('cdn/stories', {
    version: 'draft',
    starts_with: 'blog/',
    content_type: 'blogPost',
  });
  return data.stories.map((story) => ({
    params: { slug: story.slug },
    props: { story },
  }));
}

const { story } = Astro.props;
const c = story.content;
---
<BaseLayout title={`${c.meta_title || c.title} · Paktum`} description={c.meta_description || c.excerpt || ''}>
  <StoryblokComponent blok={c} />
  <div class="article-foot">
    <a class="back-link" href="/blog">← Zurück zum Blog</a>
  </div>
</BaseLayout>

<style>
  .article-foot { max-width: 720px; margin: 0 auto; padding: 32px; margin-bottom: 48px; }
  .back-link { color: var(--color-primary); text-decoration: none; font-weight: 600; font-size: 15px; }
  .back-link:hover { text-decoration: underline; }
</style>
