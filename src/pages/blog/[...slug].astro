---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPost from '../../storyblok/BlogPost.astro';
import { useStoryblokApi } from '@storyblok/astro';

export async function getStaticPaths() {
  const storyblokApi = useStoryblokApi();
  const { data } = await storyblokApi.get('cdn/stories', {
    version: import.meta.env.DEV ? 'draft' : 'published',
    starts_with: 'blog/',
    content_type: 'blogPost',
  });
  return data.stories.map((story) => ({
    params: { slug: story.slug },
    props: { story },
  }));
}

const { story } = Astro.props;
const c = story.content;
const enUrl = c.available_en ? `/blog/en/${story.slug}` : null;
---
<BaseLayout title={`${c.meta_title || c.title} · Paktum`} description={c.meta_description || c.excerpt || ''} lang="de" deUrl={`/blog/${story.slug}`} enUrl={enUrl}>
  <BlogPost blok={c} lang="de" />
  <div class="article-foot"><a class="back-link" href="/blog">← Zurück zum Blog</a></div>
</BaseLayout>
